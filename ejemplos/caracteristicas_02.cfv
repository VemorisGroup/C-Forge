// C-Forge 0.2: tipos, lógica, listas y mapas
sea tecnologias: lista = ["C++", "C#", "Python"];
agregar(tecnologias, "C-Forge");

sea proyecto: mapa = {
    "nombre": "C-Forge",
    "empresa": "Vemoris Group"
};

sea activo: booleano = verdadero;

si (activo y longitud(tecnologias) >= 4) {
    mostrar(proyecto["nombre"]);
    mostrar(tecnologias);
    mostrar("Cantidad:");
    mostrar(longitud(tecnologias));
}
